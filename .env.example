# ── LiveKit 云服务凭据 ─────────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── 本地 LLM 服务 ───────────────────────────────────────────────────────────
# FunASR / CosyVoice 插件配置固定在 src/plugins/<provider>/config.py。
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
LLM_API_KEY=not-needed
LLM_TEMPERATURE=0.6
LLM_MAX_COMPLETION_TOKENS=256

# ── 本地视觉输入 ───────────────────────────────────────────────────────────
# ENABLE_VIDEO=true 时，Agent 会订阅用户摄像头/屏幕共享视频轨道，
# 每轮用户说完后把最新一帧注入给本地 VL 模型。不要高频连续喂帧，延迟和显存会涨很快。
ENABLE_VIDEO=true
VISION_INFERENCE_WIDTH=512
VISION_INFERENCE_HEIGHT=512
# 视频帧需要在用户 turn 结束后注入，因此默认关闭预生成，避免模型还没看到图就开始回答。
PREEMPTIVE_GENERATION=false

# ── 日志配置 ───────────────────────────────────────────────────────────────
# LOG_LEVEL     : DEBUG / INFO / WARNING / ERROR（默认 INFO）
# LOG_FORMAT    : text（彩色可读）或 json（结构化，适合 ELK/Datadog）（默认 text）
# LOG_FILE      : 日志文件路径，留空则只输出到控制台
# LOG_ROTATION  : 按大小："10 MB" / "512 KB" / "1 GB"
#                 按时间："midnight"（每天）/ "H"（每小时）/ "W0"（每周一）
# LOG_RETENTION : 保留的历史文件份数（按时间时即保留天/小时数，默认 30）
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=logs/agent.log
LOG_ROTATION=midnight
LOG_RETENTION=30
